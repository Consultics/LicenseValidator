<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2011/08/nuspec.xsd">
	<metadata>
	<id>Consultics.XrmToolBox.LicenseValidator</id>
	<version>1.6.1</version>
	<title>License Validator</title>
	<authors>Martin Jäger, Consultics AG</authors>
	<owners>Consultics</owners>
	<requireLicenseAcceptance>false</requireLicenseAcceptance>
	<projectUrl>https://github.com/Consultics/LicenseValidator</projectUrl>
	<iconUrl>https://consultics.ch/wp-content/uploads/2024/09/Logo-CONSULTICS.svg</iconUrl>
	<description>XrmToolBox plugin that validates Dynamics 365 / Dataverse user license assignments against actual security role rights, usage data and Microsoft Graph API information. Flags underlicensed, overlicensed and inactive users with Excel export.</description>
	<summary>Validates Dynamics 365 user license assignments against actual rights, usage and Graph data.</summary>
	<releaseNotes>Initial public release.</releaseNotes>
	<copyright>Copyright © 2025 Martin Jäger, Consultics AG</copyright>
	<tags>XrmToolBox Dynamics365 Dataverse License Audit Graph CRM Plugin</tags>
	<dependencies>
		<dependency id="XrmToolBoxPackage" version="1.2025.7.71" />
	</dependencies>
	</metadata>
	<files>
	<file src="bin\Release\LicenceValidator.dll" target="lib\net48\Plugins" />
	</files>
</package>
